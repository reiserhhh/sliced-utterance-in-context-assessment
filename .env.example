# Copy this file to `.env` for local runs. Do not commit `.env`.

# DeepSeek / OpenAI-compatible blind-coding provider.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_LEADER_MODEL=deepseek-chat

# Optional OpenAI-compatible provider used by scripts/run_suica_independent_llm_coder_v1.py.
OPENAI_API_KEY=

# Local or remote Ollama endpoints. Keep private LAN addresses in `.env`, not in committed code.
SUICA_OLLAMA_QWEN_HOST=http://127.0.0.1:11434
SUICA_OLLAMA_LLAMA_HOST=http://127.0.0.1:11434
SUICA_OLLAMA_MISTRAL_HOST=http://127.0.0.1:11434

SUICA_QWEN_MODEL=qwen3:8b
SUICA_LLAMA_MODEL=llama3.1:8b
SUICA_MISTRAL_MODEL=persona-mistral-7b-q8:latest
