{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SUICA V7 Estimand Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "manifests"],
  "properties": {
    "registry_version": {"type": "string", "minLength": 1},
    "manifests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "estimand_id", "version", "target_object", "reference_population",
          "occasion_definition", "operator_registry", "representation",
          "null_hypothesis", "minimum_detectable_effect", "decision_rule",
          "claim_boundary"
        ],
        "properties": {
          "estimand_id": {"type": "string", "minLength": 1},
          "version": {"type": "string", "minLength": 1},
          "target_object": {
            "enum": [
              "relative_geometry", "shared_subspace", "fixed_coordinate",
              "free_selection_q", "fixed_response_B", "external_anchor"
            ]
          },
          "reference_population": {"type": "object", "minProperties": 1},
          "occasion_definition": {"type": "object", "minProperties": 1},
          "operator_registry": {"type": "object", "minProperties": 1},
          "representation": {"type": "object", "minProperties": 1},
          "null_hypothesis": {"type": "string", "minLength": 1},
          "minimum_detectable_effect": {"type": "object", "minProperties": 1},
          "decision_rule": {"type": "object", "minProperties": 1},
          "claim_boundary": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
