{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SUICA V7 Flat Factor Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "version",
    "operator",
    "representation",
    "feature_names",
    "feature_impute",
    "feature_center",
    "feature_scale",
    "fa_mean",
    "factor_loadings",
    "noise_variance",
    "factor_signs",
    "norm_mean",
    "norm_scale",
    "norm_quantiles",
    "support_rule",
    "runtime_artifact",
    "reference_population",
    "claim_boundary",
    "created_utc"
  ],
  "properties": {
    "bundle_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "operator": {"type": "object", "minProperties": 1},
    "representation": {"type": "object", "minProperties": 1},
    "feature_names": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "feature_impute": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "feature_center": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "feature_scale": {"type": "array", "minItems": 1, "items": {"type": "number", "exclusiveMinimum": 0}},
    "fa_mean": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "factor_loadings": {"type": "array", "minItems": 1, "items": {"type": "array", "minItems": 1, "items": {"type": "number"}}},
    "noise_variance": {"type": "array", "minItems": 1, "items": {"type": "number", "exclusiveMinimum": 0}},
    "factor_signs": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "norm_mean": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "norm_scale": {"type": "array", "minItems": 1, "items": {"type": "number", "exclusiveMinimum": 0}},
    "norm_quantiles": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "array", "minItems": 1, "items": {"type": "number"}}},
    "support_rule": {"type": "object", "minProperties": 1},
    "runtime_artifact": {"type": "object", "minProperties": 1},
    "reference_population": {"type": "object", "minProperties": 1},
    "claim_boundary": {"type": "string", "minLength": 1},
    "created_utc": {"type": "string", "minLength": 1},
    "factor_content_sha256": {
      "description": "SHA-256 over all score-defining fields (2026-07 tamper binding). Optional so bundles frozen before the binding keep validating; null is treated as absent.",
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
