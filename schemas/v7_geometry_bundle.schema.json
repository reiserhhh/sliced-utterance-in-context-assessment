{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SUICA V7 Relative Geometry Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "version",
    "feature_names",
    "feature_impute",
    "feature_center",
    "metric_whitener",
    "metric_regularization",
    "reference_landmarks",
    "reference_distance_summary",
    "support_rule",
    "runtime_artifact",
    "reference_population",
    "operator",
    "representation",
    "claim_boundary",
    "created_utc"
  ],
  "properties": {
    "bundle_id": {"type": "string", "pattern": "^SU7-GEO-[0-9a-f]{24}$"},
    "version": {"type": "string", "minLength": 1},
    "feature_names": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "feature_impute": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "feature_center": {"type": "array", "minItems": 1, "items": {"type": "number"}},
    "metric_whitener": {"type": "array", "minItems": 1, "items": {"type": "array", "minItems": 1, "items": {"type": "number"}}},
    "metric_regularization": {"type": "number", "exclusiveMinimum": 0},
    "reference_landmarks": {"type": "array", "minItems": 1, "items": {"type": "array", "minItems": 1, "items": {"type": "number"}}},
    "reference_distance_summary": {"type": "object", "minProperties": 1},
    "support_rule": {
      "type": "object",
      "required": [
        "min_units_for_score",
        "radial_envelope_rule",
        "density_or_domain_support_estimated"
      ],
      "properties": {
        "min_units_for_score": {"type": "integer", "minimum": 1},
        "radial_envelope_rule": {"type": "string", "minLength": 1},
        "density_or_domain_support_estimated": {"const": false}
      }
    },
    "runtime_artifact": {"type": "object", "minProperties": 1},
    "reference_population": {"type": "object", "minProperties": 1},
    "operator": {"type": "object", "minProperties": 1},
    "representation": {"type": "object", "minProperties": 1},
    "claim_boundary": {"type": "string", "minLength": 1},
    "created_utc": {"type": "string", "minLength": 1}
  }
}
